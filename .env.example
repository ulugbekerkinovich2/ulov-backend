# =============================================================================
# ULOV+ Backend — environment variables
# Copy to `.env` and fill in. Never commit the real `.env`.
# =============================================================================

# ---- Runtime -----------------------------------------------------------------
APP_ENV=dev                           # dev | staging | prod
APP_NAME=ulov-backend
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_VERSION=0.1.0
APP_LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
APP_LOG_JSON=false                    # true in prod

# ---- CORS --------------------------------------------------------------------
# Comma-separated origins. In prod: https://app.ulov.uz,https://admin.ulov.uz
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# ---- Database ---------------------------------------------------------------
DATABASE_URL=postgresql+psycopg2://ulov:ulov@postgres:5432/ulov
DATABASE_POOL_SIZE=10
DATABASE_POOL_MAX_OVERFLOW=20
DATABASE_ECHO=false

# ---- Redis ------------------------------------------------------------------
# Logical DB layout:
#   0 - cache
#   1 - otp
#   2 - refresh tokens
#   3 - arq jobs
#   4 - pub-sub (WS fan-out)
REDIS_URL=redis://redis:6379
REDIS_CACHE_DB=0
REDIS_OTP_DB=1
REDIS_REFRESH_DB=2
REDIS_ARQ_DB=3
REDIS_PUBSUB_DB=4

# ---- Auth / JWT -------------------------------------------------------------
JWT_SECRET=change-me-in-every-env-this-is-not-a-real-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_SECONDS=900            # 15 min
JWT_REFRESH_TTL_SECONDS=2592000       # 30 days
REFRESH_COOKIE_NAME=ulov_refresh
REFRESH_COOKIE_SECURE=false           # true in staging/prod
REFRESH_COOKIE_SAMESITE=strict

# ---- OTP --------------------------------------------------------------------
OTP_TTL_SECONDS=120
OTP_MAX_ATTEMPTS=5
OTP_LOCK_SECONDS=600                  # 10 min
OTP_DEV_ECHO=true                     # return OTP in response in dev only — NEVER in prod

# ---- S3 / MinIO -------------------------------------------------------------
S3_ENDPOINT_URL=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=ulovminio
S3_SECRET_KEY=ulovminio
S3_BUCKET=ulov
S3_PRESIGN_EXPIRES_SECONDS=600

# ---- Internal admin panel (sqladmin) ----------------------------------------
# When all three are set, the panel is mounted at GET /admin behind a single
# username/password login. Leave empty to disable. Pick a long random session
# secret in prod; rotating it logs everyone out.
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# ---- SMS providers (Phase 7) ------------------------------------------------
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_FROM=4546                       # sender / alphanumeric
PLAYMOBILE_LOGIN=
PLAYMOBILE_PASSWORD=
PLAYMOBILE_FROM=

# ---- Payment providers (Phase 6/7) ------------------------------------------
PAYME_MERCHANT_ID=
PAYME_SECRET=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=

# ---- Observability ----------------------------------------------------------
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ---- Rate limits ------------------------------------------------------------
RATE_LIMIT_AUTH_PER_MINUTE=5
RATE_LIMIT_WRITE_PER_MINUTE=30
RATE_LIMIT_READ_PER_MINUTE=120

# ---- Misc -------------------------------------------------------------------
DEFAULT_LANGUAGE=uz
TIMEZONE=Asia/Tashkent
