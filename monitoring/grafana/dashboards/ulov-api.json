      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "fieldConfig": {"defaults": {"unit": "reqps", "decimals": 2}},
      "targets": [{"expr": "sum(rate(http_requests_total{job=\"ulov-api\"}[1m]))", "refId": "A"}]
    },
    {
      "type": "stat",
      "title": "Error rate (5xx, 5m)",
      "gridPos": {"x": 8, "y": 0, "w": 4, "h": 4},
      "id": 3,
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.01}, {"color": "red", "value": 0.05}]}
        }
      },
      "targets": [{
        "expr": "sum(rate(http_requests_total{job=\"ulov-api\",status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total{job=\"ulov-api\"}[5m])), 1)",
        "refId": "A"
      }]
    },
    {
      "type": "stat",
      "title": "P95 latency (5m)",
      "gridPos": {"x": 12, "y": 0, "w": 4, "h": 4},
